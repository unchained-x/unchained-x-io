{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"files": {
		"includes": [
			"app/**/*.ts",
			"app/**/*.tsx",
			"app/**/*.css",
			"workers/**/*.ts",
			"vite.config.ts",
			"react-router.config.ts",
			"biome.json"
		]
	}
}
